@model List<Employee_Department.Models.Manager>
@{
    var isAdmin = User.IsInRole("Admin");
}

@if (Model.Count == 0)
{
    <tr><td colspan="7" class="text-center text-muted py-4">ไม่พบข้อมูลหัวหน้าแผนก</td></tr>
}
else
{
    int i = 1;
    foreach (var m in Model)
    {
        <tr data-id="@m.ManagerId">
            <td>@i</td>
            <td class="fw-semibold">@m.FullName</td>
            <td><span class="dept-badge">@m.Department?.DepartmentName</span></td>
            <td class="national-id">@m.NationalId</td>
            <td>@m.PhoneNumber</td>
            <td>@m.Email</td>
            <td>
                <a href="/Managers/Details/@m.ManagerId" class="btn btn-sm btn-outline-info">
                    <i class="far fa-eye"></i> ดู
                </a>
                @if (isAdmin)
                {
                    <a href="/Managers/Edit/@m.ManagerId" class="btn btn-sm btn-warning">
                        <i class="far fa-edit"></i> จัดการ
                    </a>
                    <button type="button" class="btn btn-sm btn-danger"
                            onclick="deleteManager(@m.ManagerId, '@Html.Raw(m.FullName.Replace("'", "\\'"))')">
                        <i class="far fa-trash-alt"></i> ลบ
                    </button>
                }
            </td>
        </tr>
        i++;
    }
}