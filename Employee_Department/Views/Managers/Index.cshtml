@{
    ViewData["Title"] = "รายชื่อหัวหน้าแผนก";
    var isAdmin = User.IsInRole("Admin");
    var managers = ViewBag.Managers as List<Employee_Department.Models.Manager>
                   ?? new List<Employee_Department.Models.Manager>();
    var search = ViewBag.Search as string ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="page-title m-0">
        <i class="fas fa-user-tie text-primary"></i> รายชื่อหัวหน้าแผนก
    </h2>
    @if (isAdmin)
    {
        <div class="d-flex gap-2">
            <a asp-action="ExportExcel" class="btn btn-outline-success">
                <i class="far fa-file-excel"></i> Export Excel
            </a>
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus-circle"></i> เพิ่มหัวหน้าแผนก
            </a>
        </div>
    }
</div>

<div class="card mb-3 card-form">
    <div class="card-body">
        <form id="searchForm" class="row g-3">
            <div class="col-md-9">
                <label class="form-label fw-semibold">ค้นหา (ชื่อ / เลขประชาชน / เบอร์โทร / อีเมล)</label>
                <input type="text" id="searchInput" value="@search" class="form-control" placeholder="พิมพ์ชื่อ เลขประชาชน เบอร์โทร หรืออีเมล..." />
            </div>
            <div class="col-md-3 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary flex-fill">
                    <i class="fas fa-search"></i> ค้นหา
                </button>
                <button type="button" id="resetBtn" class="btn btn-outline-secondary" title="ล้างตัวกรอง">
                    <i class="fas fa-redo"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th style="width:80px;">ลำดับ</th>
                    <th>ชื่อ-นามสกุล</th>
                    <th>แผนกที่รับผิดชอบ</th>
                    <th>เลขประชาชน</th>
                    <th>เบอร์โทร</th>
                    <th>อีเมล</th>
                    <th style="width:240px;">การดำเนินการ</th>
                </tr>
            </thead>
            <tbody id="mgrTableBody">
                @await Html.PartialAsync("ManagerRows", managers)
            </tbody>
        </table>
    </div>
    <div class="card-footer text-muted small">
        ทั้งหมด <span id="mgrCount">@managers.Count</span> คน
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        const token = $('input[name="__RequestVerificationToken"]').val();

        function loadList() {
            const search = $('#searchInput').val().trim();
            $('#mgrTableBody').html('<tr><td colspan="7" class="text-center text-muted py-4"><i class="fas fa-spinner fa-spin"></i> กำลังโหลด...</td></tr>');

            $.get('@Url.Action("GetRows")', { search: search }, function (html) {
                $('#mgrTableBody').html(html);
                const count = $('#mgrTableBody tr[data-id]').length;
                $('#mgrCount').text(count);
            }).fail(function () {
                $('#mgrTableBody').html('<tr><td colspan="7" class="text-center text-danger">โหลดข้อมูลล้มเหลว</td></tr>');
            });
        }

        async function deleteManager(id, name) {
            const ok = await confirmAction(
                `ยืนยันการลบหัวหน้าแผนก "${name}"?`,
                'ข้อมูลจะถูกย้ายไปยังถังขยะ',
                'ลบ',
                'ยกเลิก'
            );
            if (!ok) return;

            $.ajax({
                url: `/Managers/Delete/${id}`,
                type: 'POST',
                data: { id: id, __RequestVerificationToken: token },
                success: function (res) {
                    if (res.success) {
                        notify.success(res.message);
                        $(`tr[data-id="${id}"]`).fadeOut(300, function () {
                            $(this).remove();
                            const remain = $('#mgrTableBody tr[data-id]').length;
                            $('#mgrCount').text(remain);
                        });
                    } else {
                        notify.error(res.message);
                    }
                },
                error: function () { notify.error('ลบไม่สำเร็จ'); }
            });
        }

        $('#searchForm').on('submit', function (e) { e.preventDefault(); loadList(); });
        $('#resetBtn').on('click', function () { $('#searchInput').val(''); loadList(); });

        let typingTimer;
        $('#searchInput').on('input', function () {
            clearTimeout(typingTimer);
            typingTimer = setTimeout(loadList, 400);
        });
    </script>
}