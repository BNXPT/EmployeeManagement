@model Employee_Department.Models.LeaveRequest
@{
    ViewData["Title"] = $"คำขอลา #{Model.LeaveRequestId:D5}";
    var (badgeClass, statusText, icon) = Model.Status switch
    {
        "Pending"  => ("bg-warning text-dark", "รอพิจารณา", "fa-clock"),
        "Approved" => ("bg-success",            "อนุมัติแล้ว", "fa-check-circle"),
        "Rejected" => ("bg-danger",             "ปฏิเสธ",    "fa-times-circle"),
        _ => ("bg-secondary", Model.Status, "fa-question")
    };
    var step1Done = true;
    var step2Done = Model.Employee?.Department?.Manager != null;
    var step3Done = Model.Status != "Pending";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="page-title m-0">
        <i class="fas fa-file-alt text-info"></i> คำขอลางาน #@Model.LeaveRequestId.ToString("D5")
    </h2>
    <span class="badge @badgeClass" style="font-size:1rem;padding:8px 16px;">
        <i class="fas @icon"></i> @statusText
    </span>
</div>

<!-- Status Timeline -->
<div class="card mb-3">
    <div class="card-body">
        <div class="row text-center">
            <div class="col">
                <div class="step-icon @(step1Done ? "done" : "")">
                    <i class="fas fa-paper-plane"></i>
                </div>
                <p class="mt-2 mb-0 fw-semibold">1. ส่งคำขอ</p>
                <small class="text-muted">@Model.RequestedAt.ToThaiDateTime()</small>
            </div>
            <div class="col-auto d-flex align-items-center">
                <i class="fas fa-arrow-right text-muted"></i>
            </div>
            <div class="col">
                <div class="step-icon @(step2Done ? "done" : "")">
                    <i class="fas fa-envelope"></i>
                </div>
                <p class="mt-2 mb-0 fw-semibold">2. แจ้งหัวหน้าแผนก</p>
                <small class="text-muted">@(step2Done ? "ส่งอีเมลแล้ว" : "ยังไม่มีหัวหน้า")</small>
            </div>
            <div class="col-auto d-flex align-items-center">
                <i class="fas fa-arrow-right text-muted"></i>
            </div>
            <div class="col">
                <div class="step-icon @(step3Done ? (Model.Status == "Approved" ? "done" : "rejected") : "pending")">
                    <i class="fas @(Model.Status == "Approved" ? "fa-check" : Model.Status == "Rejected" ? "fa-times" : "fa-hourglass-half")"></i>
                </div>
                <p class="mt-2 mb-0 fw-semibold">3. ผลพิจารณา</p>
                <small class="text-muted">@(Model.RespondedAt?.ToThaiDateTime() ?? "รอหัวหน้าพิจารณา")</small>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">เลขที่คำขอ</dt><dd class="col-sm-9">#@Model.LeaveRequestId.ToString("D5")</dd>
            <dt class="col-sm-3">ชื่อพนักงาน</dt><dd class="col-sm-9">@Model.Employee?.FullName</dd>
            <dt class="col-sm-3">แผนก</dt><dd class="col-sm-9">@Model.Employee?.Department?.DepartmentName</dd>
            <dt class="col-sm-3">หัวหน้าแผนก</dt>
            <dd class="col-sm-9">@(Model.Employee?.Department?.Manager?.FullName ?? "—") <small class="text-muted">@(Model.Employee?.Department?.Manager?.Email ?? "")</small></dd>
            <dt class="col-sm-3">ประเภทการลา</dt><dd class="col-sm-9"><span class="badge bg-primary">@Model.LeaveType</span></dd>
            <dt class="col-sm-3">ช่วงวันที่</dt>
            <dd class="col-sm-9">@Model.StartDate.ToThaiDate() - @Model.EndDate.ToThaiDate() <span class="text-muted">(@Model.DaysCount วัน)</span></dd>
            <dt class="col-sm-3">เหตุผล</dt><dd class="col-sm-9">@Model.Reason</dd>
            @if (!string.IsNullOrWhiteSpace(Model.ManagerComment))
            {
                <dt class="col-sm-3">ความเห็นหัวหน้า</dt>
                <dd class="col-sm-9"><div class="alert @(Model.Status == "Approved" ? "alert-success" : "alert-danger") mb-0">@Model.ManagerComment</div></dd>
            }
        </dl>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> กลับรายการ</a>
    @if (Model.Status == "Pending")
    {
        <a asp-action="Cancel" asp-route-id="@Model.LeaveRequestId" class="btn btn-outline-danger cancel-leave-btn">
            <i class="fas fa-times"></i> ยกเลิกคำขอ
        </a>
    }
</div>

<style>
.step-icon { width:56px;height:56px;border-radius:50%;background:#e5e7eb;color:#9ca3af;
    display:flex;align-items:center;justify-content:center;margin:0 auto;font-size:1.4rem; }
.step-icon.done { background:#16a34a;color:#fff; }
.step-icon.rejected { background:#dc2626;color:#fff; }
.step-icon.pending { background:#f59e0b;color:#fff; }
</style>

@section Scripts {
    <script>
        const userRole = '@(User.IsInRole("Admin") ? "Admin" : User.IsInRole("Employee") ? "Employee" : "")';

        document.querySelectorAll('.cancel-leave-btn').forEach(link => {
            link.addEventListener('click', async (e) => {
                e.preventDefault();

                const isAdmin = userRole === 'Admin';
                const title = isAdmin ? 'ยืนยันการลบคำขอ?' : 'ยกเลิกคำขอนี้?';
                const text = isAdmin
                    ? 'คำขอจะถูกย้ายไปยังถังขยะ'
                    : 'คำขอลางานของคุณจะถูกยกเลิก';
                const confirmText = isAdmin ? 'ลบ' : 'ยกเลิกคำขอ';

                const ok = await confirmAction(title, text, confirmText, 'ปิด');
                if (ok) window.location.href = link.href;
            });
        });
    </script>
}