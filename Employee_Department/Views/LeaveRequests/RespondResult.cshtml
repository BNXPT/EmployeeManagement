@model Employee_Department.Controllers.RespondResultVM
@{
    ViewData["Title"] = "ผลการดำเนินการ";
    Layout = "_LayoutPublic";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-7">
        <div class="card shadow border-0 text-center">
            <div class="card-body p-5">
                @if (Model.Ok)
                {
                    <i class="fas fa-check-circle text-success" style="font-size:5rem;"></i>
                    <h3 class="mt-3 text-success">@Model.Message</h3>
                }
                else
                {
                    <i class="fas fa-exclamation-triangle text-warning" style="font-size:5rem;"></i>
                    <h3 class="mt-3">@Model.Message</h3>
                }

                @if (Model.LeaveRequest != null)
                {
                    <hr class="my-4" />
                    <div class="text-start small">
                        <p class="mb-1"><strong>เลขที่:</strong> #@Model.LeaveRequest.LeaveRequestId.ToString("D5")</p>
                        <p class="mb-1"><strong>พนักงาน:</strong> @Model.LeaveRequest.Employee?.FullName</p>
                        <p class="mb-1"><strong>ประเภท:</strong> @Model.LeaveRequest.LeaveType</p>
                        <p class="mb-0"><strong>สถานะ:</strong> @Model.LeaveRequest.Status</p>
                    </div>
                }
                <a href="/" class="btn btn-primary mt-4"><i class="fas fa-home"></i> กลับหน้าหลัก</a>
            </div>
        </div>
    </div>
</div>
