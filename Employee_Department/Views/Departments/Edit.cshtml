@model Employee_Department.Models.Department
@{
    ViewData["Title"] = "แก้ไขแผนก";
}

<h2 class="page-title mb-4">
    <i class="fas fa-edit text-warning"></i> แก้ไขชื่อแผนก
</h2>
<hr />

<div class="card card-form">
    <div class="card-body p-4">
        <form asp-action="Edit">
            <input type="hidden" asp-for="DepartmentId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="DepartmentName" class="form-label fw-semibold"></label>
                <input asp-for="DepartmentName" class="form-control" />
                <span asp-validation-for="DepartmentName" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-warning">
                <i class="far fa-save"></i> บันทึกการแก้ไข
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> ยกเลิก
            </a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}