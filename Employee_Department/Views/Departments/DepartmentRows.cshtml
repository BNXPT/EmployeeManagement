@model List<Employee_Department.Services.DepartmentInfo>

@if (Model.Count == 0)
{
    <tr><td colspan="5" class="text-center text-muted py-4">ยังไม่มีแผนก</td></tr>
}
else
{
    foreach (var item in Model)
    {
        <tr data-id="@item.DepartmentId">
            <td>@item.DepartmentId</td>
            <td><span class="dept-badge">@item.DepartmentName</span></td>
            <td class="text-center">@(item.EmployeeCount + item.ManagerCount) คน</td>
            <td class="text-center">
                @if (item.HasManager)
                {
                    <i class="fas fa-check-circle text-success"></i>
                }
                else
                {
                    <i class="fas fa-times-circle text-muted"></i>
                }
            </td>
            <td>
                <button type="button" class="btn btn-sm btn-warning"
                        onclick="editDept(@item.DepartmentId)">
                    <i class="far fa-edit"></i> แก้ไข
                </button>
                <button type="button" class="btn btn-sm btn-danger"
                        onclick="deleteDept(@item.DepartmentId, '@Html.Raw(item.DepartmentName.Replace("'", "\\'"))')">
                    <i class="far fa-trash-alt"></i> ลบ
                </button>
            </td>
        </tr>
    }
}