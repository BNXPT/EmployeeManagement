@{
    ViewData["Title"] = "จัดการแผนก";
    var deptData = ViewBag.DeptData as List<dynamic> ?? new List<dynamic>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="page-title m-0">
        <i class="fas fa-building text-primary"></i> จัดการแผนก
    </h2>
    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#deptModal" onclick="openCreateModal()">
        <i class="fas fa-plus-circle"></i> เพิ่มแผนกใหม่
    </button>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th style="width:90px;">รหัส</th>
                    <th>ชื่อแผนก</th>
                    <th class="text-center">จำนวนพนักงาน</th>
                    <th class="text-center">มีหัวหน้า</th>
                    <th style="width:200px;">การดำเนินการ</th>
                </tr>
            </thead>
            <tbody id="deptTableBody">
                @await Html.PartialAsync("DepartmentRows", deptData)
            </tbody>
        </table>
    </div>
    <div class="card-footer text-muted small">
        ทั้งหมด <span id="deptCount">@deptData.Count</span> แผนก
    </div>
</div>

@* Modal Create/Edit *@
<div class="modal fade" id="deptModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="deptForm">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="deptModalTitle">เพิ่มแผนกใหม่</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="DepartmentId" name="DepartmentId" value="0" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">ชื่อแผนก</label>
                        <input type="text" class="form-control" id="DepartmentName" name="DepartmentName" required />
                        <div class="text-danger small mt-1" id="deptError"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                    <button type="submit" class="btn btn-success">
                        <i class="far fa-check-circle"></i> บันทึก
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        const token = $('input[name="__RequestVerificationToken"]').val();

        function loadList() {
            $.get('@Url.Action("GetRows")', function (html) {
                $('#deptTableBody').html(html);
                const count = $('#deptTableBody tr[data-id]').length;
                $('#deptCount').text(count);
            });
        }

        function openCreateModal() {
            $('#deptModalTitle').text('เพิ่มแผนกใหม่');
            $('#DepartmentId').val(0);
            $('#DepartmentName').val('');
            $('#deptError').text('');
        }

        function editDept(id) {
            $.get('@Url.Action("GetOne")', { id: id }, function (res) {
                if (!res.success) { notify.error(res.message); return; }
                $('#deptModalTitle').text('แก้ไขชื่อแผนก');
                $('#DepartmentId').val(res.data.departmentId);
                $('#DepartmentName').val(res.data.departmentName);
                $('#deptError').text('');
                $('#deptModal').modal('show');
            });
        }

        async function deleteDept(id, name) {
            const ok = await confirmAction(`ยืนยันการลบแผนก "${name}"?`, '', 'ลบ', 'ยกเลิก');
            if (!ok) return;

            $.ajax({
                url: '@Url.Action("Delete")',
                type: 'POST',
                data: { id: id, __RequestVerificationToken: token },
                success: function (res) {
                    if (res.success) {
                        notify.success(res.message);
                        loadList();
                    } else {
                        notify.error(res.message);
                    }
                }
            });
        }

        $('#deptForm').on('submit', function (e) {
            e.preventDefault();
            const id = $('#DepartmentId').val();
            const url = id == 0 ? '@Url.Action("Create")' : '@Url.Action("Edit")';
            const data = {
                DepartmentId: id,
                DepartmentName: $('#DepartmentName').val().trim(),
                __RequestVerificationToken: token
            };
            if (id != 0) data.id = id;

            $.ajax({
                url: url, type: 'POST', data: data,
                success: function (res) {
                    if (res.success) {
                        $('#deptModal').modal('hide');
                        notify.success(res.message);
                        loadList();
                    } else {
                        $('#deptError').text(res.message);
                    }
                }
            });
        });
    </script>
}